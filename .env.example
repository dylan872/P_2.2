# ===========================================
# Claims Guard - Environment Variables
# ===========================================

# Database Mode: "supabase" or "postgres"
# Set to "postgres" to use direct PostgreSQL connection
# Set to "supabase" (or leave empty) to use Supabase
DB_MODE=postgres

# ===========================================
# SUPABASE CONFIGURATION (when DB_MODE=supabase)
# ===========================================
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ===========================================
# POSTGRESQL CONFIGURATION (when DB_MODE=postgres)
# ===========================================
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=claims_guard
PG_USER=postgres
PG_PASSWORD=your-password

# Optional: SSL mode for production PostgreSQL
# PG_SSL=require

# ===========================================
# ML SERVICE CONFIGURATION
# ===========================================
# URL where the Python ML service is running
ML_SERVICE_URL=http://localhost:5001

# Timeout for ML service calls (in milliseconds)
ML_SERVICE_TIMEOUT=30000

# ===========================================
# ML SERVICE (Python) CONFIGURATION
# ===========================================
# Port for the ML Flask service
ML_SERVICE_PORT=5001

# Enable debug mode for ML service
ML_DEBUG=false
